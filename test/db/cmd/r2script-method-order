NAME=r2script-method-order
FILE=-
CMDS=<<CMDS_END
!!../bin/r2flutter -R bins/ios/Runner.app 2>/dev/null | perl -ne 'if (/^f method\..* = 0x([0-9a-fA-F]+)/) { $v = hex ($1); if (defined $p && $v < $p) { print "UNSORTED\n"; exit 1; } $p = $v; $count++; } END { if ($count > 0) { print "OK\n"; } else { print "NO_METHODS\n"; exit 1; } }'
CMDS_END
EXPECT=<<EXPECT_END
OK
EXPECT_END
RUN

NAME=r2script-pp-scan-skipped
FILE=-
CMDS=<<CMDS_END
!!../bin/r2flutter -R bins/android/mafia 2>/dev/null | tail -4 | head -3
CMDS_END
EXPECT=<<EXPECT_END
dr x27=`e anal.gp`
'f PP=x27
# PP offset scan skipped by default; use xrefs/analysis for pool-slot refs
EXPECT_END
RUN
