# Regression guard: Code slots whose owner is a Class must be labeled
# stub.Allocate<ClassName>Stub, not shifted into a neighboring method name by
# the name-pool fallback. 0x5b6bf4 is the AllocateDurationStub in this fixture.
NAME=funcs-mafia-allocate-stub
FILE=-
CMDS=<<EOF
!!../bin/r2flutter --dump-funcs --quiet bins/android/mafia 2>/dev/null | grep -E '^0x5b6bf4 '
EOF
EXPECT=<<EOF
0x5b6bf4 stub.AllocateDurationStub
EOF
RUN

# The same address must NOT appear under any method.fn_* fallback name, which
# was the bug before the Code-owner-cid fix.
NAME=funcs-mafia-allocate-stub-not-fallback
FILE=-
CMDS=<<EOF
!!../bin/r2flutter --dump-funcs --quiet bins/android/mafia 2>/dev/null | grep -c '^0x5b6bf4 method.fn_'
EOF
EXPECT=<<EOF
0
EOF
RUN

# Type-test stubs (Code owner is an AbstractType) must be synthesized as
# stub.typetest_* rather than pulling from the name pool.
NAME=funcs-mafia-typetest-stub-present
FILE=-
CMDS=<<EOF
!!../bin/r2flutter --dump-funcs --quiet bins/android/mafia 2>/dev/null | grep -c ' stub.typetest_'
EOF
EXPECT=<<EOF
395
EOF
RUN

# And there must be a healthy population of allocate stubs. On Dart 3.9.0 mafia
# the count is 4080; if it drops noticeably (e.g. back to zero) the owner-cid
# lookup has regressed.
NAME=funcs-mafia-allocate-stub-count
FILE=-
CMDS=<<EOF
!!../bin/r2flutter --dump-funcs --quiet bins/android/mafia 2>/dev/null | grep -c ' stub.Allocate'
EOF
EXPECT=<<EOF
4080
EOF
RUN
