!!../bin/r2flutter --dump-funcs --limit 3 bins/android/mafia 2>/dev/null
EOF
EXPECT=<<EOF
0x5b69c0 method.DateTime.compareTo
0x5b6aa4 method.Duration.compareTo
0x5b6b64 method.Duration.dyn:_
EOF
