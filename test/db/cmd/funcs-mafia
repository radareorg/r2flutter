NAME=r2-funcs-mafia
FILE=-
CMDS=<<EOF
!!../bin/r2flutter -r --dump-funcs --limit 2 bins/android/mafia 2>/dev/null
EOF
EXPECT=<<EOF
f method.fn_0 = 0x5b6940
'@0x5b6940'CC method.fn_0
f method.fn_1 = 0x5b6b61
'@0x5b6b61'CC method.fn_1
EOF
RUN

NAME=json-funcs-mafia
FILE=-
CMDS=<<EOF
